# Ignored directories
**/.claude/settings.local.json
**/__pycache__/
**/certs/
**/data/
**/mock/

# SSL/TLS certificates and keys
**/*.key
**/*.pem
**/*.crt

# Local environment files
**/*.local
**/*.secret
**/global.env
**/*override.yaml
**/.venv

# Contains real domain/host values baked in for app-level config vars
# (DOMAIN_CLIENT/DOMAIN_SERVER) that can't be Compose-interpolated from
# TRAEFIK_ACME_DOMAIN -- see ai/librechat/.env.sample for the template.
ai/librechat/.env
