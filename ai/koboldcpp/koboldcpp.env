# Full koboldcpp CLI flags, see https://github.com/LostRuins/koboldcpp/wiki
# Model path is relative to the /models mount (== DATA_DIR on the host)
KCPP_ARGS=--usecublas --gpulayers 999 --contextsize 8192 --port 5001 --host 0.0.0.0 --model /models/CHANGE_ME.gguf

# Alternative to --model above: let koboldcpp download the GGUF itself on startup
# KCPP_MODEL=https://huggingface.co/.../model.gguf
