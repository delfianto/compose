# Baseline config
ENV=dev
GLOBAL_LOG_LEVEL=INFO
USE_CUDA_DOCKER=false
USE_OLLAMA_DOCKER=false

JWT_EXPIRES_IN=4w
USER_AGENT=OpenWebUI/1.0
ENABLE_API_KEY_AUTH=false
WEBUI_SECRET_KEY=user_provided

MODEL_LIST_CACHE_TTL=300
BYPASS_MODEL_ACCESS_CONTROL=false
CHAT_RESPONSE_STREAM_DELTA_CHUNK_SIZE=1
DATABASE_URL=postgresql://openwebui:user_provided_secret@pgsql:5432/openwebui

# Vector Database Configuration
VECTOR_DB=pgvector
PGVECTOR_INDEX_METHOD=vchordrq
