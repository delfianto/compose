SWARMUI_UID=1000
SWARMUI_GID=1000

# Registry and version settings for SwarmUI
SWARMUI_VERSION=latest
GHCR_IMAGE=ghcr.io/delfianto/compose/swarmui

GPU_ID=0
SWARMUI_PORT=7801

# This is the path *INSIDE* the container
# and not inside the host file system
SWARMUI_ROOT=/SwarmUI
SWARMUI_EXTS=/SwarmUI/src/Extensions
SWARMUI_COMF=/SwarmUI/src/BuiltinExtensions/ComfyUIBackend

# This is the path for the *HOST* filesystem
DATA_DIR=/srv/appdata/genai/stablediff
SWARMUI_DATA=/srv/appdata/genai/stablediff/swarmui
SWARMUI_SRC=/srv/appdata/genai/stablediff/swarmui/src
