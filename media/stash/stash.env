# When running on root mode docker (system wide),
# set PUID and PGID to your user and group id.
#
# On rootless mode keep this as zero, the docker
# daemon will do the mapping from internal root
# into your proper user id
#
PUID=0
PGID=0
TZ=Asia/Singapore

STASH_CONFIG_HOME=/config
STASH_CACHE=/cache
STASH_GENERATED=/generated
STASH_METADATA=/metadata
STASH_STASH=/media

STASH_HW_TEST_TIMEOUT=10
SKIP_NVIDIA_PATCH=true
STASH_PORT=9069
MIGRATE=false
